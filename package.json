{
    "name": "@solidweather/components",
    "version": "0.4.2",
    "author": {
        "name": "Axel H. Karlsson",
        "url": "https://axelkarlsson.se"
    },
    "description": "A simple and tiny React UI toolkit, mainly used for SolidWeather.",
    "license": "MIT",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "docker:build": "docker compose up build-job; docker compose down build-job --rmi all",
        "docker:server": "docker compose up dev-job; docker compose down dev-job --rmi all",
        "docker:lint": "docker compose up lint-job; docker compose down lint-job --rmi all",
        "unsafe:lint": "eslint --ext .js,.jsx,.ts,.tsx .",
        "unsafe:lint:fix": "eslint --fix --ext .js,.jsx,.ts,.tsx .",
        "unsafe:build": "rm -rf dist/* && vite build && tsc --project tsconfig.json && rm -rf dist/dev",
        "unsafe:server": "vite",
        "version:bump:major": "npm version major --git-tag-version false",
        "version:bump:minor": "npm version minor --git-tag-version false",
        "version:bump:patch": "npm version patch --git-tag-version false"
    },
    "repository": {
        "type": "git",
        "url": "https://gitlab.com/solidweather/components.git"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/components.js",
            "require": "./dist/components.umd.cjs"
        },
        "./style.css": "./dist/index.css"
    },
    "files": [
        "dist/"
    ],
    "devDependencies": {
        "@eslint/js": "9.35.0",
        "@types/node": "^24.10.1",
        "@types/react": "19.1.12",
        "@types/react-dom": "19.1.9",
        "@vitejs/plugin-react": "4.7.0",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "9.35.0",
        "eslint-plugin-react-hooks": "5.2.0",
        "eslint-plugin-react-refresh": "0.4.20",
        "globals": "16.4.0",
        "jiti": "2.5.1",
        "react": "19.1.1",
        "react-dom": "19.1.1",
        "sass": "1.93.2",
        "typescript": "5.8.3",
        "typescript-eslint": "8.43.0",
        "vite": "^7.3.2"
    },
    "dependencies": {
        "bootstrap-icons": "1.13.1"
    }
}
